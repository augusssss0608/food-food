# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY_ADMIN=
SUPABASE_SECRET_KEY_CRON=

# Anthropic（开发期不需要，MOCK_AI=1 走 mock；部署 Vercel 时填）
ANTHROPIC_API_KEY=

# AI mock 开关
# 开发期默认 1（dev 和 test 都走 MockAiProvider，不打真 API、不花钱）
# 部署 Vercel 时不要设置 / 设为 0，让 production 走真 anthropic_api
MOCK_AI=1

# Phase 3（v1 留空）
CLAUDE_AGENT_SNAPSHOT_ID=
CLAUDE_CODE_OAUTH_TOKEN=

# 单用户锁
ALLOWED_USER_ID=

# 站点
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cron
CRON_SECRET=

# Web Push（用 npx web-push generate-vapid-keys 生成）
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Dev / POC / Debug
DEV_SECRET=
